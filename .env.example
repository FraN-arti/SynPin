# ===========================================
# SynPin Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# --- Frontend ---
# API URL for the React frontend (Vite dev proxy target)
VITE_API_URL=http://localhost:2088

# --- Server ---
# Port for the SynPin API server
SYNPIN_PORT=2088

# Port for the Vite dev server (development only)
SYNPIN_DEV_PORT=2099

# Data directory for SynPin (agents, memory, logs)
# Default: ~/.synpin
SYNPIN_DATA_DIR=~/.synpin

# --- Logging ---
# Log level: debug, info, warning, error
SYNPIN_LOG_LEVEL=info
