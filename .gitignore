# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/
.venv/

# Node
node_modules/
web/dist/
web/*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store

# Runtime data (per-entity YAML, lives inside the synpin package in dev)
core/synpin/data/departments/
core/synpin/data/otdels/
Thumbs.db

# Environment
.env
.env.local

# Test dirs
test_*/

# Data (local state, not in git)
data/
logs/
*.db

# ChromaDB
chroma_data/

# User home data
~/.synpin/

# Shared user data (NEVER commit)
data/shared/

# Configs with secrets (NEVER commit)
core/synpin/config/providers.yaml

# User config (stored in ~/.synpin/config/, NOT in git)
core/synpin/config/*.yaml
# But keep templates tracked
!core/synpin/config/templates/

# Kanban user config (columns, labels, settings, widget) — per-user
# state, lives in the synpin package in dev for proximity but
# shouldn't be shared across users. Templates / defaults should
# go in core/synpin/kanban/config/templates/ if you want them
# tracked.
core/synpin/kanban/config/*.yaml
!core/synpin/kanban/config/templates/*.yaml

# Agent runtime data
core/synpin/agents/*/agent.yaml
.hermes/

# Per-entity runtime data (kanban tasks, departments, otdels)
# These live inside the synpin package in dev mode for proximity to
# the code that uses them; in prod they live at ~/.synpin/data/*.
core/synpin/data/departments/*/department.yaml
core/synpin/data/otdels/*/otdel.yaml
core/synpin/data/tasks/*.yaml

# Debug logs
stream_debug.log

# Local-only assistant context (not for GitHub)
AGENTS.md

# Graphify knowledge graph output (regenerated by `graphify update .`)
graphify-out/

# Frontend tests (local dev only, not in repo)
web/src/**/*.test.*
web/src/test/
web/vitest.config.ts


# User customization (local-only)
core/synpin/config/themes/

# Ruff linter cache (local-only)
.ruff_cache/
core/.ruff_cache/
.mypy_cache/
core/.mypy_cache/
